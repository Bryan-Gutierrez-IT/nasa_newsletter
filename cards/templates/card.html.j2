<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Command Cards — Card View</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='styles.css') }}">
</head>
<body>

  <div class="page">
    <header class="header" role="banner" aria-label="Card header">
      <div>
        <div class="h-title">Command Cards</div>
        <div class="h-sub">Individual Card View</div>
      </div>
      <div class="h-sub">
        <!--- CHANGE YOUR IP -->
        <a href="http://192.168.56.101/cards.html" style="color: var(--green2); text-decoration: none; border-bottom: 1px dashed var(--line);">
          ← Back to collection
        </a>
      </div>
    </header>

     <main style="display:grid; place-items:center; min-height: calc(100vh - 140px);">

      <!--- RARITY -->
      <article class="cmd-card" data-rarity="">
        <div class="cmd-card__accent"></div>
        <div class="cmd-card__inner">
          <div class="card-top">
            <div>
              <!--- COMMAND NAME -->
              <div class="cmd-name"></div>
              <!--- RARITY -->
              <div class="rarity-label"></div>
            </div>
          </div>
          <!--- HISTORY -->
          <div class="args"></div>

          <div class="stats">
            <div class="stat">
              <div class="k">Executions</div>
              <!--- # EXECUTIONS-->
              <div class="v"></div>
            </div>
            <div class="stat">
              <div class="k">Rank</div>
              <!--- RANK  -->
              <div class="v"></div>
            </div>
            <div class="stat">
              <div class="k">Arg Density</div>
              <!--- ARG DENSITY -->
              <div class="v"></div>
            </div>
            <div class="stat">
              <div class="k">Redirection</div>
              <!--- REDIRECTION RATE -->
              <div class="v"></div>
            </div>
          </div>

          <div class="mastery">
          <span>Mastery</span>
          <!--- MASTERY -->
          <div class="bar" style="--pct: %;">
            <span></span>
          </div>
        </div>

          <div class="footer">
            <!--- FLAVOR TEXT -->
            
          </div>
        </div>
      </article>
    
    <div><p><small>Click card to copy the card code</small></p></div>
    </main>
  </div>

  

  <!--- BASE64 encoded card -->
<div id="cardBase64" style="display:none;">

</div>
  <script>
  (function () {
    const base64El = document.getElementById('cardBase64');
    if (!base64El) return;

    const base64 = base64El.textContent.trim();

    // Target the single card on the page
    const card = document.querySelector('.cmd-card');
    if (!card) return;

    // Optional: show feedback in the footer
    const footer = card.querySelector('.footer');
    const originalFooter = footer ? footer.textContent : null;

    async function copyToClipboard(text) {
      // Primary path
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return;
      }
      // Fallback path (older browsers / non-secure contexts)
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }

    function flashFeedback(ok) {
      if (!footer) return;

      footer.textContent = ok ? '"Copied card code"' : '"Something went wrong with copying"';
      footer.style.opacity = '1';

      setTimeout(() => {
        footer.textContent = originalFooter ?? '';
      }, 1200);
    }

    card.addEventListener('click', async (e) => {
      // If the card is an <a href="#">, prevent jumping
      if (card.tagName.toLowerCase() === 'a') {
        e.preventDefault();
      } else {
        // If click occurs inside a link within the card, avoid navigation
        const link = e.target.closest('a');
        if (link) e.preventDefault();
      }

      try {
        await copyToClipboard(base64);
        flashFeedback(true);
      } catch (err) {
        console.error('Copy failed', err);
        flashFeedback(false);
      }
    });

    // Optional: make it feel clickable
    card.style.cursor = 'copy';
    card.setAttribute('title', 'Click to copy Base64 card code');
  })();
</script>
</body>
</html>