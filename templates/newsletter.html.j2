<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>NASA APOD Newsletter</title>
  <link rel="stylesheet" href="css/bootstrap.css">
</head>
<body>
  <div class="container">
    <h1>NASA APOD Newsletter</h1>

    {% for entry in entries %}
    <div class="card mb-4">
      <div class="card-body">
        <h2 class="card-title">{{ entry.title }}</h2>
        <p><strong>Date:</strong> {{ entry.date }}</p>
        <p><strong>Author:</strong> {{ entry.author }}</p>
        <img src="img/{{ entry.image_name }}" alt="{{ entry.title }}" width="600">
        <p class="mt-3">{{ entry.explanation }}</p>
      </div>
    </div>
    {% endfor %}
  </div>
</body>
</html>
